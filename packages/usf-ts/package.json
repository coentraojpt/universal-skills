{
  "name": "@universal-skills/core",
  "version": "0.1.0",
  "description": "Universal LLM Skills Framework — TypeScript loader and adapters.",
  "keywords": ["llm", "prompt", "skills", "openai", "anthropic", "gemini", "ollama", "obsidian"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "render-all": "tsx scripts/render_all.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coentraojpt/universal-skills"
  }
}
