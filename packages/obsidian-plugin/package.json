  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  }
}
