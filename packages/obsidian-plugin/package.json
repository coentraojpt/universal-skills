{
  "name": "@universal-skills/obsidian-plugin",
  "version": "0.1.0",
  "description": "Obsidian plugin for the Universal LLM Skills Framework.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "esbuild main.ts --bundle --format=cjs --platform=node --external:obsidian --outfile=main.js --sourcemap --watch",
