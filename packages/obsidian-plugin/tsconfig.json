{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["DOM", "ES2022"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": ["main.ts"]
}
